      "type": "string",
      "description": "The formatted log line text"
    },
    "operation": {
      "type": "string",
      "enum": [
        "inserted",
        "removed"
      ],
      "description": "Type of operation"
    },
    "notes": {
      "type": "string",
      "description": "Optional notes"
    }
  },
  "required": [
    "line",
    "operation"
  ]
}